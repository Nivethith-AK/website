# Appwrite (full backend)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_DATABASE_ID=avantae-db
APPWRITE_STORAGE_BUCKET_ID=your-storage-bucket-id
APPWRITE_API_KEY=replace-with-appwrite-api-key

# Frontend (Vercel)
NEXTAUTH_URL=https://your-frontend-domain.com
NEXTAUTH_SECRET=replace-with-strong-random-secret
FRONTEND_URL=https://your-frontend-domain.com

# Legacy API mode (only if you still run custom Express API)
NEXT_PUBLIC_API_URL=https://your-backend-domain.com/api

# Admin bootstrap (optional but recommended)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_EMAILS=admin@your-domain.com,coadmin@your-domain.com

# Backend (if you still run custom API server)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRE=7d
FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-gmail-address@gmail.com
PORT=5000
NODE_ENV=production

# Optional local-development fallback (do not use in production)
DEV_TEST_EMAIL=backup-dev-login@gmail.com
DEV_TEST_PASSWORD=123456
